{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "YoptaScript",
  "scopeName": "source.yoptascript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.yoptascript",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.block.yoptascript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "storage.type.yoptascript",
          "match": "(?<!\\w)(?:褍褔邪褋褌泻芯胁褘泄|褟褋械薪啸褍泄|携褋械薪啸褍泄|锌懈蟹写褞谢懈|泻谢褢胁芯|泻谢械胁芯|泄芯锌褌邪|邪褋褋芯|褞蟹邪泄|谐褘褘)(?!\\w)"
        },
        {
          "name": "storage.modifier.yoptascript",
          "match": "(?<!\\w)(?:锌芯锌芯薪褟褌懈褟|锌芯写泻褉褘褕邪|械斜邪薪薪芯械|斜邪褌褟|屑芯泄)(?!\\w)"
        },
        {
          "name": "keyword.control.yoptascript",
          "match": "(?<!\\w)(?:胁懈谢泻芯泄胁谐谢邪蟹|懈谢懈胁卸芯锌褍褉邪蟹|褋懈写械褌褜袧邪褏褍泄|薪邪芯褌褘斜懈褋褜|邪械褋谢懈薪邪泄写褍|褔芯褍薪邪褋褌褍褌|锌芯械斜邪谢褍薪邪|锌芯褌褉械褖懈屑|邪褔褢薪械褌邪泻|邪褔械薪械褌邪泻|邪褔械薪懈褌邪泻|锌芯斜褉邪褌褋泻懈|锌邪斜褉邪褌褋泻懈|褋锌懈蟹写懈褌褜|锌褉械写褗褟胁邪|褋邪褕邪袚褉械泄|锌芯械斜邪谢褍|褌褞褉褟卸泻邪|斜邪蟹邪褉锌芯|锌邪斜褉邪褑泻懈|谢芯谐芯锌械写|芯褌胁械褔邪褞|写胁懈谐邪泄|褏邪锌薪褍褌褜|械褋褌褜褔芯|泻褉褍褌邪薪懈|芯褌泻褍写邪|锌邪褏邪薪褍|邪锌芯褏褍泄|褏邪褉褝|泻懈写邪泄|褌械屑邪|薪褍懈褔芯|泻褉褔|谐芯锌|锌薪褏|谢械褖|泻褍泻褍|懈蟹|谐芯)(?!\\w)"
        },
        {
          "name": "variable.language.yoptascript",
          "match": "(?<!\\w)(?:褌褘褉褘锌褘褉褘|褟谐邪)(?!\\w)"
        },
        {
          "name": "keyword.operator.word.yoptascript",
          "match": "(?<!\\w)(?:蟹邪褏褍褟褉懈褌褜|褔械蟹邪卸懈卸邪薪|谐褘泄斜邪褌褜|褢斜薪褍褌褜|械斜薪褍褌褜|褕泻褍褉邪)(?!\\w)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.yoptascript",
          "match": "(?<!\\w)(?:锌褉邪胁写邪|褌褉褍谢懈芯|褔褢褌泻芯|褔械褌泻芯|褔芯褌泻芯|谢芯卸|薪械褌褉褍谢懈芯|锌懈蟹写懈褕褜|薪械褔褢褌泻芯|薪械褔械褌泻芯|薪械褔芯褌泻芯|薪芯谢褜|薪褍谢谢懈芯|锌芯褉芯卸薪褟泻|薪械懈斜褍)(?!\\w)"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.yoptascript",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "string.quoted.single.yoptascript",
          "begin": "'",
          "end": "'",
          "patterns": [{ "include": "#string-escape" }]
        },
        {
          "name": "string.template.yoptascript",
          "begin": "`",
          "end": "`",
          "patterns": [
            { "include": "#string-escape" },
            {
              "name": "meta.template.expression.yoptascript",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.yoptascript" } },
              "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.yoptascript" } },
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "string-escape": {
      "name": "constant.character.escape.yoptascript",
      "match": "\\\\(?:x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|u[0-9A-Fa-f]{4}|.)"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.yoptascript",
          "match": "(?<!\\w)0[xX][0-9A-Fa-f][0-9A-Fa-f_]*n?(?!\\w)"
        },
        {
          "name": "constant.numeric.octal.yoptascript",
          "match": "(?<!\\w)0[oO][0-7][0-7_]*n?(?!\\w)"
        },
        {
          "name": "constant.numeric.binary.yoptascript",
          "match": "(?<!\\w)0[bB][01][01_]*n?(?!\\w)"
        },
        {
          "name": "constant.numeric.decimal.yoptascript",
          "match": "(?<!\\w)(?:[0-9][0-9_]*\\.?[0-9_]*|\\.[0-9][0-9_]*)(?:[eE][+-]?[0-9_]+)?n?(?!\\w)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.yoptascript",
          "match": "(\\+\\+|--|&&|\\|\\||\\?\\?|===|!==|==|!=|<=|>=|=>|\\.\\.\\.|[-+*/%<>=!&|^~?:])"
        }
      ]
    }
  }
}
