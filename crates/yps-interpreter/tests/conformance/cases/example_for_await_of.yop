ассо йопта собрать() {
    гыы обещания = [
        СловоПацана.решить(1),
        СловоПацана.решить(2),
        СловоПацана.решить(3),
        СловоПацана.решить(4)
    ];
    гыы сумма = 0;
    го сидетьНахуй (х сашаГрей обещания) {
        сказать("получил", х);
        сумма += х;
    }
    отвечаю сумма;
}

собрать().потом((итог) => {
    сказать("итог:", итог);
});
