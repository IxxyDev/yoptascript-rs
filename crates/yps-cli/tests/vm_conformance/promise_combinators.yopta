ассо йопта главная() {
    гыы всех = сидетьНахуй СловоПацана.всех([СловоПацана.решить(1), 2, СловоПацана.решить(3)]);
    сказать("всех:", всех);

    гыы устаканить = сидетьНахуй СловоПацана.всехУстаканить([
        СловоПацана.решить("ок"),
        СловоПацана.отвергнуть("плохо")
    ]);
    сказать("устаканить[0]:", устаканить[0].статус, устаканить[0].значение);
    сказать("устаканить[1]:", устаканить[1].статус, устаканить[1].причина);

    гыы любой = сидетьНахуй СловоПацана.любой([
        СловоПацана.отвергнуть("нет"),
        СловоПацана.решить("да")
    ]);
    сказать("любой:", любой);

    гыы гонка = сидетьНахуй СловоПацана.гонка([
        СловоПацана.решить("первый"),
        СловоПацана.решить("второй")
    ]);
    сказать("гонка:", гонка);
}

главная();
