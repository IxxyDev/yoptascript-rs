гыы об = { значения: [1, 2, 3] };
об[Симбол.итератор] = йопта() {
    гыы источник = об.значения;
    гыы индекс = 0;
    отвечаю {
        следующий: йопта() {
            вилкойвглаз (индекс < длина(источник)) {
                гыы зн = источник[индекс];
                индекс = индекс + 1;
                отвечаю { значение: зн, готово: лож };
            } иливжопураз {
                отвечаю { значение: ноль, готово: правда };
            }
        }
    };
};

сказать([...об]);
сказать([0, ...об, 99]);

йопта ф(а, б, в) { отвечаю а + б + в; }
сказать(ф(...об));

гыы сумма = 0;
го (гыы х сашаГрей об) { сумма = сумма + х; }
сказать(сумма);

гыы пусто = {};
пусто[Симбол.итератор] = йопта() {
    отвечаю { следующий: йопта() { отвечаю { значение: ноль, готово: правда }; } };
};
сказать([...пусто]);

гыы [п, в] = об;
сказать(п);
сказать(в);

гыы [первый, ...остаток] = об;
сказать(первый);
сказать(остаток);

йопта разбор([а, б, в]) { отвечаю а + б + в; }
сказать(разбор(об));
