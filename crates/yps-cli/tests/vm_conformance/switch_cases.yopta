йопта оцени(х) {
  базарпо (х) {
    тема 1: { сказать("один"); }
    тема 2: { сказать("два"); }
    тема 3: { сказать("три"); }
    нуичо { сказать("иное: " + х); }
  }
}
оцени(1);
оцени(2);
оцени(3);
оцени(7);

йопта поСтроке(с) {
  базарпо (с) {
    тема "а": { сказать("буква а"); }
    тема "б": { сказать("буква б"); }
    нуичо { сказать("неизвестно"); }
  }
}
поСтроке("а");
поСтроке("б");
поСтроке("в");

го (гыы и = 0; и < 4; и++) {
  базарпо (и) {
    тема 0: { сказать("ноль"); }
    тема 2: { харэ; }
    нуичо { сказать("деф " + и); }
  }
}

йопта безДефолта(х) {
  базарпо (х) {
    тема 10: { сказать("десять"); }
  }
  сказать("после свича " + х);
}
безДефолта(10);
безДефолта(99);
