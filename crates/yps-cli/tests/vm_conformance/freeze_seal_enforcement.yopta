гыы замороженный = { а: 1, б: 2 };
Кент.заморозить(замороженный);
замороженный.а = 999;
замороженный.новое = 7;
замороженный["а"] = 888;
замороженный["ещё"] = 8;
ёбнуть замороженный.б;
сказать(замороженный);
сказать(Кент.заморожен(замороженный));
сказать(Кент.запечатан(замороженный));
сказать(Кент.расширяем(замороженный));

