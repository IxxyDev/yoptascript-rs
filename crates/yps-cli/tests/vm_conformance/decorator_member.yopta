йопта обёртка(метод, контекст) {
    отвечаю (а, б) => {
        отвечаю метод(а, б) * 2;
    };
}

йопта удесятерить(_, контекст) {
    отвечаю (начальное) => {
        отвечаю начальное * 10;
    };
}

клёво Счёт {
    @удесятерить
    значение = 5;

    @обёртка
    сложить(а, б) {
        отвечаю а + б;
    }

    @обёртка
    попонятия статМетод(а, б) {
        отвечаю а - б;
    }
}

гыы с = захуярить Счёт();
сказать(с.значение);
сказать(с.сложить(3, 4));
сказать(Счёт.статМетод(10, 3));
