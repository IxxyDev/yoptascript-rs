пиздюли сКэтчем() {
    хапнуть {
        поебалу 1;
        поебалу 2;
    } гоп (e) {
        сказать("внутри поймал:", e);
        поебалу 100;
    }
    поебалу 3;
}
гыы г = сКэтчем();
сказать("y1:", г.следующий().значение);
гыы р = г.кинуть("бум");
сказать("после throw:", р.значение, р.готово);
сказать("y3:", г.следующий().значение);
сказать("конец:", г.следующий().готово);

пиздюли безКэтча() {
    поебалу 1;
    поебалу 2;
}
гыы г2 = безКэтча();
сказать("y:", г2.следующий().значение);
хапнуть {
    г2.кинуть("наружу");
} гоп (e) {
    сказать("снаружи поймал:", e);
}
сказать("после непойманного:", г2.следующий().готово);

пиздюли наСтарте() {
    поебалу 1;
}
гыы г3 = наСтарте();
хапнуть {
    г3.кинуть("до старта");
} гоп (e) {
    сказать("на старте поймал:", e);
}

пиздюли завершён() {
    поебалу 1;
}
гыы г4 = завершён();
г4.следующий();
г4.следующий();
хапнуть {
    г4.кинуть("после конца");
} гоп (e) {
    сказать("на завершённом поймал:", e);
}
