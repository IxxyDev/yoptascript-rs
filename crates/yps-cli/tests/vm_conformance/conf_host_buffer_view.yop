участковый буф = захуярить ОбластьБайтов(16);
сказать(тип(буф));
сказать(буф.длинаБайт);
участковый вид = захуярить ОбзорБайтов(буф);
вид.задатьЦ8(0, 200);
вид.задатьЧ32(1, -12345);
вид.задатьДр64(8, 3.5);
сказать(вид.взятьЦ8(0));
сказать(вид.взятьЧ32(1));
сказать(вид.взятьДр64(8));
сказать(тип(вид));
