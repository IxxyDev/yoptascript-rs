пиздюли простой() {
    поебалу 1;
    поебалу 2;
    поебалу 3;
}
гыы г = простой();
сказать("y1:", г.следующий().значение);
гыы р = г.вернуть(42);
сказать("ret:", р.значение, р.готово);
сказать("после:", г.следующий().значение, г.следующий().готово);

пиздюли сФиналли() {
    хапнуть {
        поебалу "a";
        поебалу "b";
    } тюряжка {
        сказать("финалли выполнен");
    }
}
гыы г2 = сФиналли();
сказать("y:", г2.следующий().значение);
гыы р2 = г2.вернуть("стоп");
сказать("ret2:", р2.значение, р2.готово);

пиздюли финаллиОверрайд() {
    хапнуть {
        поебалу "x";
    } тюряжка {
        отвечаю "из-финалли";
    }
}
гыы г3 = финаллиОверрайд();
сказать("y3:", г3.следующий().значение);
гыы р3 = г3.вернуть("игнор");
сказать("ret3:", р3.значение, р3.готово);
