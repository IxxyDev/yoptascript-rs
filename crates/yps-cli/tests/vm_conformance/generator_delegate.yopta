пиздюли внутр() {
  поебалу "а";
  поебалу "б";
  отвечаю "ВНУТР_РЕТ";
}

пиздюли внеш() {
  поебалу "начало";
  гыы захват = поебалуна внутр();
  сказать("захват=" + захват);
  поебалу "конец";
}

го (гыы з сашаГрей внеш()) {
  сказать("дел: " + з);
}

пиздюли числа() {
  поебалу 1;
  поебалу 2;
}
пиздюли буквы() {
  поебалу "x";
  поебалу "y";
}
пиздюли смесь() {
  поебалуна числа();
  поебалуна буквы();
  поебалуна [100, 200];
  поебалуна "пр";
}
го (гыы м сашаГрей смесь()) {
  сказать("м=" + м);
}

ясенХуй все = [...смесь()];
сказать(все);
