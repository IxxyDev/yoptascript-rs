пиздюли двусторонний() {
  гыы а = поебалу 1;
  сказать("получил а=" + а);
  гыы б = поебалу 2;
  сказать("получил б=" + б);
  отвечаю а + б;
}

ясенХуй г = двусторонний();
сказать(г.следующий("игнор").значение);
сказать(г.следующий(10).значение);
ясенХуй р = г.следующий(20);
сказать(р.значение + " " + р.готово);

пиздюли эхо() {
  гыы п1 = поебалу "готов";
  гыы п2 = поебалу ("эхо:" + п1);
  гыы п3 = поебалу ("эхо:" + п2);
  отвечаю "эхо:" + п3;
}
ясенХуй э = эхо();
сказать(э.следующий().значение);
сказать(э.следующий("раз").значение);
сказать(э.следующий("два").значение);
ясенХуй кон = э.следующий("три");
сказать(кон.значение + " " + кон.готово);
