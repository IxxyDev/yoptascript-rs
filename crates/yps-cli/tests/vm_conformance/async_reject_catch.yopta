ассо йопта плохо() {
    кидай "облом";
}

ассо йопта черезОбъект() {
    кидай { причина: "сломалось", код: 42 };
}

ассо йопта главная() {
    хапнуть {
        сидетьНахуй плохо();
    } гоп (e) {
        сказать("поймано строку:", e);
    }
    хапнуть {
        сидетьНахуй черезОбъект();
    } гоп (e) {
        сказать("поймано объект:", e.причина, e.код);
    }
}

главная();

СловоПацана.отвергнуть("реджект").ловить((e) => сказать("ловить:", e));
