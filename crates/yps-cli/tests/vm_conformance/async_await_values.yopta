ассо йопта получить(x) {
    отвечаю x * 2;
}

ассо йопта главная() {
    гыы а = сидетьНахуй получить(10);
    гыы б = сидетьНахуй 5;
    гыы в = сидетьНахуй СловоПацана.решить(7);
    сказать("а:", а);
    сказать("б:", б);
    сказать("в:", в);
    отвечаю а + б + в;
}

главная().потом((итог) => сказать("итог:", итог));
сказать("синхронный конец");
