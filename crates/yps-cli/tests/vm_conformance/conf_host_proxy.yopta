ясенХуй цель = { баланс: 100 };
ясенХуй п = захуярить Посредник(цель, {
  получить: (ц, ключ) => {
    вилкойвглаз (ключ чоунастут ц) {
      отвечаю ц[ключ];
    }
    отвечаю "нет поля: " + ключ;
  },
  установить: (ц, ключ, значение) => {
    вилкойвглаз (ключ === "баланс" && значение < 0) {
      кидай "баланс не может быть отрицательным";
    }
    ц[ключ] = значение;
    отвечаю правда;
  }
});
сказать(п.баланс);
сказать(п.секрет);
п.баланс = 250;
сказать(п.баланс);
сказать("баланс" чоунастут п);
хапнуть {
  п.баланс = -5;
} гоп (е) {
  сказать("поймали: " + е);
}
ясенХуй сложить = захуярить Посредник((а, б) => а + б, {
  применить: (ц, этот, арг) => {
    сказать("вызов:", арг[0], арг[1]);
    отвечаю ц(арг[0], арг[1]);
  }
});
сказать(сложить(7, 8));
