ассо йопта главная() {
    гыы модуль = сидетьНахуй спиздить("./модуль_библиотека.yopta");
    сказать("версия:", модуль.ВЕРСИЯ);
    сказать("удвоить:", модуль.удвоить(21));
    гыы внутр = модуль.внутр;
    сказать("внутр:", внутр);
}

главная().ловить((e) => сказать("ошибка:", e));

спиздить(42).ловить((e) => сказать("неверный аргумент:", e));
