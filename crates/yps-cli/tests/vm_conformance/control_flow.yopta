гыы сумма = 0;
го (гыы и = 0; и < 10; и++) {
    вилкойвглаз (и == 7) { харэ; }
    вилкойвглаз (и % 2 == 0) { двигай; }
    сумма += и;
}
сказать("сумма нечётных <7:", сумма);

гыы счёт = 0;
гыы к = 0;
потрещим (к < 4) {
    счёт += к * к;
    к++;
}
сказать("сумма квадратов:", счёт);

го (гыы а = 0; а < 3; а++) {
    го (гыы б = 0; б < 3; б++) {
        сказать("ячейка", а, б);
    }
}

йопта классификация(н) {
    вилкойвглаз (н > 0) {
        отвечаю "положительное";
    } иливжопураз вилкойвглаз (н < 0) {
        отвечаю "отрицательное";
    }
    отвечаю "ноль";
}
сказать(классификация(10), классификация(-3), классификация(0));
