йопта точка({ х, у }) {
    отвечаю х + у;
}
сказать(точка({ х: 3, у: 4 }));

йопта первыйдва([а, б]) {
    отвечаю а * б;
}
сказать(первыйдва([6, 7]));

йопта сдефолтом({ а, б = 10 }) {
    отвечаю а + б;
}
сказать(сдефолтом({ а: 1 }), сдефолтом({ а: 1, б: 2 }));

йопта сверестом([первый, ...прочие]) {
    отвечаю первый + длина(прочие);
}
сказать(сверестом([1, 2, 3, 4]));
