йопта сРезультатом() {
  хапнуть {
    отвечаю "возврат из трая";
  } тюряжка {
    сказать("финал при возврате");
  }
}
сказать(сРезультатом());

хапнуть {
  хапнуть {
    кидай "глубоко";
  } гоп (е) {
    сказать("внутр: " + е);
    кидай "переброшено";
  } тюряжка {
    сказать("внутр финал");
  }
} гоп (е) {
  сказать("внешн: " + е);
} тюряжка {
  сказать("внешн финал");
}

йопта черезВызов() {
  кидай "из вызова";
}
хапнуть {
  черезВызов();
} гоп (е) {
  сказать("из вызова поймал: " + е);
}

тюряжкаТолько();
йопта тюряжкаТолько() {
  хапнуть {
    хапнуть {
      кидай "только финал";
    } тюряжка {
      сказать("финал без catch");
    }
  } гоп (е) {
    сказать("поймал после финала: " + е);
  }
}

