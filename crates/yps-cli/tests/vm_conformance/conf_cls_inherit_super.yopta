клёво Зверь {
  Зверь(имя) { тырыпыры.имя = имя; }
  голос() { отвечаю "..."; }
  опис() { отвечаю "Зверь:" + тырыпыры.имя; }
}
клёво Пёс батя Зверь {
  Пёс(имя) { яга(имя); }
  голос() { отвечаю яга.голос() + "гав"; }
}
ясенХуй п = захуярить Пёс("Рекс");
сказать(п.имя);
сказать(п.голос());
сказать(п.опис());
сказать(п шкура Пёс);
сказать(п шкура Зверь);
