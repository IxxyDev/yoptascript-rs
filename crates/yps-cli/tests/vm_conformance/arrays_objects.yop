гыы числа = [1, 2, 3, 4, 5];
сказать("массив:", числа);
сказать("длина:", длина(числа));
числа[2] = 99;
сказать("после правки:", числа);
втолкнуть(числа, 6);
сказать("после втолкнуть:", числа);

гыы пользователь = { имя: "Йопта", возраст: 3, активен: правда };
сказать("имя:", пользователь.имя);
сказать("возраст:", пользователь["возраст"]);
пользователь.возраст = 4;
сказать("новый возраст:", пользователь.возраст);

гыы записи = [ { счёт: 0 }, { счёт: 0 } ];
записи[0].счёт = 42;
записи[1].счёт = записи[0].счёт + 8;
сказать("записи:", записи[0].счёт, записи[1].счёт);

гыы ключ = "вычислено";
гыы динам = { [ключ]: 123 };
сказать("вычисленный ключ:", динам.вычислено);

гыы матрица = [ [1, 2], [3, 4] ];
сказать("матрица[1][0]:", матрица[1][0]);
