гыы точка = { х: 1, у: 2 };
гыы суммаХ = 0;
го (гыы и = 0; и < 5; и = и + 1) {
    суммаХ = суммаХ + точка.х;
}
сказать("сумма х:", суммаХ);

точка.х = 100;
суммаХ = 0;
го (гыы и = 0; и < 3; и = и + 1) {
    суммаХ = суммаХ + точка.х;
}
сказать("сумма после правки:", суммаХ);

точка.z = 9;
сказать("новый ключ:", точка.z, "старый:", точка.х);

ёбнуть точка.у;
сказать("после удаления:", точка);

йопта прочти(о) {
    отвечаю о.значение;
}
гыы а = { значение: "А" };
гыы б = { значение: "Б" };
го (гыы и = 0; и < 6; и = и + 1) {
    вилкойвглаз (и % 2 == 0) {
        сказать(прочти(а));
    } иливжопураз {
        сказать(прочти(б));
    }
}

йопта пиши(о, в) {
    о.поле = в;
    отвечаю о.поле;
}
гыы п1 = { поле: 0 };
гыы п2 = { поле: 0 };
сказать(пиши(п1, 11), пиши(п2, 22), пиши(п1, 33));

гыы счётчик = { n: 0 };
го (гыы и = 0; и < 4; и = и + 1) {
    счётчик.n = счётчик.n + 1;
}
сказать("счётчик до заморозки:", счётчик.n);
Кент.заморозить(счётчик);
счётчик.n = 999;
сказать("счётчик после заморозки:", счётчик.n);

гыы тик = 0;
гыы датчик = {
    get текущий() {
        тик = тик + 1;
        отвечаю тик;
    }
};
го (гыы и = 0; и < 3; и = и + 1) {
    сказать("датчик:", датчик.текущий);
}

клёво Ячейка {
    вес = 0;
    Ячейка(вес) {
        тырыпыры.вес = вес;
    }
    удвой() {
        отвечаю тырыпыры.вес * 2;
    }
}
гыы я1 = захуярить Ячейка(3);
гыы я2 = захуярить Ячейка(7);
гыы сумВес = 0;
го (гыы и = 0; и < 4; и = и + 1) {
    сумВес = сумВес + я1.вес + я2.вес;
}
сказать("сумма весов:", сумВес);
я1.вес = 50;
сказать("после правки веса:", я1.вес, я1.удвой());
сказать("метод как значение:", тип(я2.удвой));
