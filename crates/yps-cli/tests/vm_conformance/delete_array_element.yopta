гыы массив = [10, 20, 30, 40];
ёбнуть массив[1];
сказать("длина:", длина(массив));
сказать("1 из массива:", 1 из массив);
сказать("3 из массива:", 3 из массив);
сказать("10 из массива:", 10 из массив);
сказать("массив[1]:", массив[1]);
го (гыы и = 0; и < длина(массив); и = и + 1) {
    сказать("элемент", и, "=", массив[и]);
}
сказать("массив:", массив);
