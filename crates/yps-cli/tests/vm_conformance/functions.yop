йопта факт(н) {
    вилкойвглаз (н <= 1) { отвечаю 1; }
    отвечаю н * факт(н - 1);
}
сказать("факт(6):", факт(6));

йопта фиб(н) {
    вилкойвглаз (н < 2) { отвечаю н; }
    отвечаю фиб(н - 1) + фиб(н - 2);
}
сказать("фиб(10):", фиб(10));

йопта счётчик() {
    гыы н = 0;
    отвечаю () => {
        н += 1;
        отвечаю н;
    };
}
гыы с = счётчик();
сказать("счётчик:", с(), с(), с());

йопта сложить(а, б = 100) {
    отвечаю а + б;
}
сказать("умолчание:", сложить(1), сложить(1, 2));

йопта сумма(...числа) {
    гыы итог = 0;
    го (гыы и = 0; и < длина(числа); и++) {
        итог += числа[и];
    }
    отвечаю итог;
}
сказать("rest:", сумма(1, 2, 3, 4, 5));

гыы удвоить = (х) => х * 2;
сказать("стрелка:", удвоить(21));
