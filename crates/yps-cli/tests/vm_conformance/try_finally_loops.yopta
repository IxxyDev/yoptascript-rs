гыы сумма = 0;
го (гыы и = 0; и < 6; и++) {
  хапнуть {
    вилкойвглаз (и == 2) { двигай; }
    вилкойвглаз (и == 5) { харэ; }
    сумма += и;
  } тюряжка {
    сказать("финал и=" + и);
  }
}
сказать("сумма=" + сумма);

внешний:
го (гыы а = 0; а < 3; а++) {
  го (гыы б = 0; б < 3; б++) {
    хапнуть {
      вилкойвглаз (а == 1 && б == 1) { харэ внешний; }
      сказать("a" + а + "b" + б);
    } тюряжка {
      сказать("ф" + а + б);
    }
  }
}
сказать("после меток");
