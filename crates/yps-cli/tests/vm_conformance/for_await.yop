ассо йопта собрать() {
    гыы обещания = [
        СловоПацана.решить(1),
        СловоПацана.решить(2),
        СловоПацана.решить(3)
    ];
    гыы сумма = 0;
    го сидетьНахуй (х сашаГрей обещания) {
        сказать("шаг:", х);
        сумма += х;
    }
    сказать("сумма:", сумма);
    отвечаю сумма;
}

собрать().потом((итог) => сказать("итог:", итог));
