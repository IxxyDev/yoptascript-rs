пиздюли счёт() {
  поебалу 1;
  поебалу 2;
  поебалу 3;
}

участковый г = счёт();
участковый а = г.следующий();
сказать(а.значение + " " + а.готово);
участковый б = г.следующий();
сказать(б.значение + " " + б.готово);
участковый ц = г.следующий();
сказать(ц.значение + " " + ц.готово);
участковый д = г.следующий();
сказать(д.значение + " " + д.готово);
участковый е = г.следующий();
сказать(е.значение + " " + е.готово);

сказать(тип(счёт()));

пиздюли диапазон(старт, конец) {
  го (гыы и = старт; и < конец; и += 1) {
    поебалу и;
  }
}
гыы сумма = 0;
го (гыы х сашаГрей диапазон(1, 6)) {
  сумма = сумма + х;
}
сказать("сумма=" + сумма);

участковый сп = [...диапазон(10, 14)];
сказать(сп);
