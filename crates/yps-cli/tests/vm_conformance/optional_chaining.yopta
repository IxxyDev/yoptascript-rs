гыы н = ноль;
гыы непределён = неибу;

сказать(н?.поле);
сказать(непределён?.поле);

гыы об = { имя: "Объект", вложенный: { значение: 42 } };
сказать(об?.имя);
сказать(об?.вложенный?.значение);

сказать(н?.[0]);
гыы масс = [10, 20, 30];
сказать(масс?.[1]);
сказать(н?.[5]);

гыы сМетодом = {
  привет: йопта() { отвечаю "хай"; },
  число: 5
};
сказать(сМетодом.привет?.());
сказать(н?.());

гыы данные = { список: [1, 2, 3] };
сказать(данные?.список?.[2]);
сказать(данные?.отсутствует?.[0]);

йопта получить(о) {
  отвечаю о?.значение;
}
сказать(получить({ значение: 99 }));
сказать(получить(ноль));
