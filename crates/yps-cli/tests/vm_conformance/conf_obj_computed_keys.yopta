участковый к = "ключ";
участковый о = { [к]: 1, ["а" + "б"]: 2, [3 + 4]: 9 };
сказать(о.ключ);
сказать(о.аб);
сказать(о[7]);

участковый н = 0;
участковый о2 = { [н]: "ноль", [н + 1]: "один" };
сказать(о2[0]);
сказать(о2[1]);

клёво Ф {
  Ф() {
    тырыпыры["динамика"] = 42;
  }
}
участковый ф = захуярить Ф();
сказать(ф.динамика);
