йопта f({ x, y }) {
  сказать(x, y);
}
f({ x: 1, y: 2 });

йопта g([a, b]) {
  сказать(a, b);
}
g([10, 20]);

йопта h({ x = 5 } = {}) {
  сказать(x);
}
h();
h({ x: 99 });

йопта multi({ name }, [first]) {
  сказать(name, first);
}
multi({ name: "Иван" }, ["привет"]);

гыы arrow = ({ a, b }) => a + b;
сказать(arrow({ a: 3, b: 4 }));
