участковый числа = [1, 2, 3, 4, 5];
сказать(тип(Итератор));
участковый квадраты = Итератор.от(числа).преобразовать((н) => н * н).вМассив();
сказать(квадраты);
участковый первые = Итератор.от(числа).взять(3).вМассив();
сказать(первые);
участковый чётные = Итератор.от(числа).отфильтровать((н) => н % 2 === 0).вМассив();
сказать(чётные);
участковый сумма = Итератор.от(числа).свернуть((а, б) => а + б, 0);
сказать(сумма);
участковый склеено = Итератор.склеить([1, 2], [3, 4]).вМассив();
сказать(склеено);
