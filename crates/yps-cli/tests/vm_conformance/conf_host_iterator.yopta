ясенХуй числа = [1, 2, 3, 4, 5];
сказать(тип(Итератор));
ясенХуй квадраты = Итератор.от(числа).преобразовать((н) => н * н).вМассив();
сказать(квадраты);
ясенХуй первые = Итератор.от(числа).взять(3).вМассив();
сказать(первые);
ясенХуй чётные = Итератор.от(числа).отфильтровать((н) => н % 2 === 0).вМассив();
сказать(чётные);
ясенХуй сумма = Итератор.от(числа).свернуть((а, б) => а + б, 0);
сказать(сумма);
ясенХуй склеено = Итератор.склеить([1, 2], [3, 4]).вМассив();
сказать(склеено);
