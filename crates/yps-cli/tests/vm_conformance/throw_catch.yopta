йопта проверь(н) {
  вилкойвглаз (н < 0) {
    кидай "отрицательное: " + н;
  }
  отвечаю н * 2;
}

хапнуть {
  сказать(проверь(5));
  сказать(проверь(-3));
  сказать(проверь(10));
} гоп (е) {
  сказать("перехват: " + е);
}

йопта глубокийКид() {
  йопта уровень2() {
    йопта уровень3() {
      кидай "со дна";
    }
    уровень3();
  }
  уровень2();
}

хапнуть {
  глубокийКид();
} гоп (е) {
  сказать("дно поймано: " + е);
}

хапнуть {
  кидай 42;
} гоп (код) {
  сказать("числовой код: " + код);
}

хапнуть {
  кидай { тип: "ошибка", сообщение: "плохо" };
} гоп (об) {
  сказать("объект: " + об.тип + "/" + об.сообщение);
}

хапнуть {
  кидай "без параметра";
} гоп {
  сказать("поймано без биндинга");
}

сказать("все перехваты завершены");
