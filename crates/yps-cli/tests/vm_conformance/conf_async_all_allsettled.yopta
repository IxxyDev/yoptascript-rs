йопта задержка(значение, мс) {
    отвечаю захуярить СловоПацана((решить, _) => {
        чутка(() => решить(значение), мс);
    });
}

ассо йопта main() {
    гыы упорядочено = сидетьНахуй СловоПацана.всех([
        задержка("a", 15),
        задержка("b", 5),
        задержка("c", 10)
    ]);
    сказать("всех порядок:", упорядочено[0], упорядочено[1], упорядочено[2]);

    хапнуть {
        сидетьНахуй СловоПацана.всех([
            СловоПацана.решить(1),
            СловоПацана.отвергнуть("первая боль"),
            СловоПацана.решить(3)
        ]);
    } гоп (e) {
        сказать("всех отклонён:", e);
    }

    гыы устакан = сидетьНахуй СловоПацана.всехУстаканить([
        СловоПацана.решить("ок1"),
        СловоПацана.отвергнуть("плохо"),
        СловоПацана.решить("ок2")
    ]);
    го (гыы э сашаГрей устакан) {
        вилкойвглаз (э.статус === "выполнено") {
            сказать(э.статус, "значение=" + э.значение);
        } иливжопураз {
            сказать(э.статус, "причина=" + э.причина);
        }
    }
}
main();
