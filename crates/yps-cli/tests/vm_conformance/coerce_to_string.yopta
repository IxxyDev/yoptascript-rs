клёво Точка {
    Точка(х, у) {
        тырыпыры.х = х;
        тырыпыры.у = у;
    }
    вСтроку() {
        отвечаю "(" + тырыпыры.х + ", " + тырыпыры.у + ")";
    }
}

гыы точка = захуярить Точка(1, 2);
сказать("класс concat:", "точка = " + точка);
сказать("класс tmpl:", `точка = ${точка}`);

гыы объект = {
    вСтроку() {
        отвечаю "СВОЙ";
    }
};
сказать("объект concat:", "об = " + объект);
сказать("объект + число:", объект + 5);

гыы примитив = {
    [Симбол.вПримитив](подсказка) {
        отвечаю 42;
    }
};
сказать("вПримитив + число:", примитив + 8);
сказать("вПримитив + строка:", примитив + " хвост");
