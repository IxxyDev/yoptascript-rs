гыы об = { первый: 1, второй: 2, третий: 3 };
го (гыы ключ чоунастут об) {
  сказать(ключ + "=" + об[ключ]);
}

гыы масс = [100, 200, 300];
го (гыы знач чоунастут масс) {
  сказать("элемент " + знач);
}

го (гыы зн сашаГрей [5, 10, 15]) {
  сказать("of " + зн);
}

гыы сумма = 0;
го (гыы н сашаГрей [1, 2, 3, 4]) {
  сумма += н;
}
сказать("сумма of=" + сумма);

го (гыы с сашаГрей "привет") {
  сказать("симв " + с);
}

го (гыы х сашаГрей [1, 2, 3, 4, 5]) {
  вилкойвглаз (х == 4) { харэ; }
  вилкойвглаз (х % 2 == 0) { двигай; }
  сказать("нечёт " + х);
}

гыы пусто = [];
го (гыы э сашаГрей пусто) {
  сказать("не печатается");
}
сказать("пустой of ок");
