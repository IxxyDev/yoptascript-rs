гыы пары = [[1, 2], [3, 4], [5, 6]];
го (гыы [а, б] сашаГрей пары) {
  сказать(а + "," + б);
}

гыы точки = [{ х: 10, у: 20 }, { х: 30, у: 40 }];
го (ясенХуй { х, у } сашаГрей точки) {
  сказать(х + ":" + у);
}

го (гыы [первый, ...хвост] сашаГрей [[1, 2, 3, 4]]) {
  сказать(первый + " / " + хвост);
}

го (гыы [а = 100, б = 200] сашаГрей [[1], [], [7, 8]]) {
  сказать(а + "-" + б);
}

го (гыы { к: { л } } сашаГрей [{ к: { л: 42 } }, { к: { л: 99 } }]) {
  сказать("вложенный " + л);
}

гыы замыкания = [];
го (гыы [к, зн] сашаГрей [["a", 1], ["b", 2], ["c", 3]]) {
  замыкания.втолкнуть(() => к + "=" + зн);
}
го (гыы ф сашаГрей замыкания) {
  сказать(ф());
}

гыы сумма = 0;
го (гыы [а, б] сашаГрей [[1, 1], [2, 2], [3, 3], [9, 9]]) {
  вилкойвглаз (а == 3) { двигай; }
  вилкойвглаз (а == 9) { харэ; }
  сумма += а + б;
}
сказать("сумма=" + сумма);

пиздюли ген() {
  го (гыы [а, б] сашаГрей [[1, 2], [3, 4], [5, 6]]) {
    поебалу а + б;
  }
}
гыы вых = [];
го (гыы х сашаГрей ген()) {
  вых.втолкнуть(х);
}
сказать(вых);
