предъява участковый ВЕРСИЯ = "2.0";

предъява йопта удвоить(х) {
    отвечаю х * 2;
}

предъява клёво Точка {
    Точка(х, у) {
        тырыпыры.х = х;
        тырыпыры.у = у;
    }
    сумма() {
        отвечаю тырыпыры.х + тырыпыры.у;
    }
}

гыы внутр = 777;
предъява { внутр };

йопта приватная() {
    отвечаю "не экспортируется";
}
