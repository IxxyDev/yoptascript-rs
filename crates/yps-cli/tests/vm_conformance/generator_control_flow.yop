пиздюли чётные(предел) {
  го (гыы и = 0; и < предел; и += 1) {
    вилкойвглаз (и % 2 != 0) { двигай; }
    поебалу и;
  }
}
го (гыы ч сашаГрей чётные(10)) {
  сказать("чёт " + ч);
}

пиздюли доПервого(предел) {
  гыы и = 0;
  потрещим (и < предел) {
    вилкойвглаз (и == 4) { харэ; }
    поебалу и;
    и += 1;
  }
  поебалу "хвост";
}
участковый г = доПервого(100);
гыы вывод = "";
гыы шаг = г.следующий();
потрещим (!шаг.готово) {
  вывод = вывод + шаг.значение + ",";
  шаг = г.следующий();
}
сказать(вывод);

пиздюли замыкание() {
  гыы счёт = 0;
  потрещим (счёт < 3) {
    счёт += 1;
    поебалу счёт * 10;
  }
}
участковый з = замыкание();
сказать(з.следующий().значение);
сказать(з.следующий().значение);
сказать(з.следующий().значение);
сказать(з.следующий().готово);

пиздюли вложенныйЦикл() {
  го (гыы а = 0; а < 2; а += 1) {
    го (гыы б = 0; б < 2; б += 1) {
      поебалу ("" + а + б);
    }
  }
}
го (гыы п сашаГрей вложенныйЦикл()) {
  сказать("пара " + п);
}
