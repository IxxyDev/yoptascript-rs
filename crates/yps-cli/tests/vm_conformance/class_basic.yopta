клёво Точка {
    х = 0;
    у = 0;
    Точка(х, у) {
        тырыпыры.х = х;
        тырыпыры.у = у;
    }
    сумма() {
        отвечаю тырыпыры.х + тырыпыры.у;
    }
    опис() {
        отвечаю "(" + тырыпыры.х + ", " + тырыпыры.у + ")";
    }
}

гыы т = захуярить Точка(3, 4);
сказать(т.х);
сказать(т.у);
сказать(т.сумма());
сказать(т.опис());
сказать(т);
сказать(т шкура Точка);

гыы пуст = захуярить Точка(0, 0);
пуст.х = 10;
сказать(пуст.сумма());
сказать(тип(Точка));
