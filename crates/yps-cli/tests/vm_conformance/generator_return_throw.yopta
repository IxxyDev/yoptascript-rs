пиздюли ген() {
  поебалу 1;
  поебалу 2;
  поебалу 3;
}

участковый г = ген();
сказать(г.следующий().значение);
участковый р = г.вернуть(42);
сказать("ret " + р.значение + " " + р.готово);
сказать("после " + г.следующий().готово);

пиздюли уловитель() {
  хапнуть {
    поебалу "а";
    поебалу "б";
  } гоп (е) {
    сказать("поймал внутри: " + е);
    поебалу "восстановлен";
  } тюряжка {
    сказать("финал-уловителя");
  }
}
участковый г2 = уловитель();
сказать(г2.следующий().значение);
сказать(г2.кинуть("БУМ").значение);
сказать(г2.следующий().готово);

пиздюли простой() {
  поебалу 1;
  поебалу 2;
}
участковый г3 = простой();
сказать(г3.следующий().значение);
хапнуть {
  г3.кинуть("вылетело наружу");
} гоп (е) {
  сказать("внешний поймал: " + е);
}
сказать("g3 done=" + г3.следующий().готово);
