йопта запомнить(класс, контекст) {
    сказать("декорируем " + контекст.вид + " " + контекст.имя);
    отвечаю класс;
}

йопта подменить(класс, контекст) {
    отвечаю класс;
}

@запомнить
@подменить
клёво Тачка {
    Тачка(марка) {
        тырыпыры.марка = марка;
    }
    показать() {
        отвечаю "Тачка: " + тырыпыры.марка;
    }
}

гыы т = захуярить Тачка("Лада");
сказать(т.показать());
сказать(т шкура Тачка);
