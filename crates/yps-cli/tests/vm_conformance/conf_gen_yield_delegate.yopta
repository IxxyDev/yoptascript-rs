пиздюли вн() {
    гыы а = поебалу "вн1";
    сказать("вн получил:", а);
    гыы б = поебалу "вн2";
    сказать("вн получил:", б);
    отвечаю "вн-конец";
}
пиздюли внеш() {
    поебалу "до";
    поебалуна вн();
    поебалу "после";
}
гыы г = внеш();
сказать(г.следующий().значение);
сказать(г.следующий("S0").значение);
сказать(г.следующий("S1").значение);
сказать(г.следующий("S2").значение);
сказать(г.следующий().готово);

пиздюли внФиналли() {
    хапнуть {
        поебалу "i1";
        поебалу "i2";
    } тюряжка {
        сказать("вн финалли");
    }
}
пиздюли внешРет() {
    поебалуна внФиналли();
    поебалу "недостижимо";
}
гыы г2 = внешРет();
сказать(г2.следующий().значение);
гыы р = г2.вернуть("СТОП");
сказать("delegate ret:", р.значение, р.готово);

пиздюли внКэтч() {
    хапнуть {
        поебалу "j1";
        поебалу "j2";
    } гоп (e) {
        сказать("вн поймал:", e);
        поебалу "восстановлен";
    }
}
пиздюли внешThrow() {
    поебалуна внКэтч();
    поебалу "хвост";
}
гыы г3 = внешThrow();
сказать(г3.следующий().значение);
гыы р3 = г3.кинуть("БАХ");
сказать("delegate throw:", р3.значение, р3.готово);
сказать(г3.следующий().значение);
