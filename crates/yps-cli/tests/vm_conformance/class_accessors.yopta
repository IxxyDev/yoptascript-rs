клёво Темп {
    Темп() {
        тырыпыры._ц = 0;
    }
    get цельсий() {
        отвечаю тырыпыры._ц;
    }
    set цельсий(в) {
        тырыпыры._ц = в;
    }
    get фаренгейт() {
        отвечаю тырыпыры._ц * 9 / 5 + 32;
    }
}

гыы т = захуярить Темп();
сказать(т.цельсий);
сказать(т.фаренгейт);
т.цельсий = 100;
сказать(т.цельсий);
сказать(т.фаренгейт);

клёво ПодТемп батя Темп {
    ПодТемп() {
        яга();
    }
    get удвоенный() {
        отвечаю тырыпыры.цельсий * 2;
    }
}
гыы п = захуярить ПодТемп();
п.цельсий = 21;
сказать(п.цельсий);
сказать(п.удвоенный);

клёво Т2 {
    Т2() {
        тырыпыры.х = 10;
    }
    стрела = () => тырыпыры.х;
    обычный() {
        отвечаю тырыпыры.х;
    }
}
гыы д = захуярить Т2();
сказать(д.обычный());
сказать(д.стрела());
гыы оторван = д.стрела;
сказать(оторван());
