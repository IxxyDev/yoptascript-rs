сказать("факт(5) до объявления:", факт(5));

йопта факт(н) {
    вилкойвглаз (н <= 1) { отвечаю 1; }
    отвечаю н * факт(н - 1);
}

сказать("чёт(6):", чёт(6), "нечёт(6):", нечёт(6));

йопта чёт(н) {
    вилкойвглаз (н == 0) { отвечаю правда; }
    отвечаю нечёт(н - 1);
}

йопта нечёт(н) {
    вилкойвглаз (н == 0) { отвечаю лож; }
    отвечаю чёт(н - 1);
}

йопта внешняя() {
    гыы префикс = "метка:";
    йопта пометить(с) { отвечаю префикс + с; }
    отвечаю пометить("вызов до текста");
}
сказать(внешняя());
