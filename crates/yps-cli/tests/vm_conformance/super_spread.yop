клёво Зверь {
    Зверь(а, б, в) {
        тырыпыры.клич = а + "-" + б + "-" + в;
    }
    звук(а, б) {
        отвечаю а + "/" + б;
    }
}

клёво Кот батя Зверь {
    Кот(...аргс) {
        яга(...аргс);
    }
    позвать(...части) {
        отвечаю яга.звук(...части);
    }
}

гыы к = захуярить Кот("мяу", "мур", "фыр");
сказать(к.клич);
сказать(к.позвать("левый", "правый"));
