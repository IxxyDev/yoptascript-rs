// YoptaScript interop-пример — оригинальный стиль samgozman/YoptaScript.
// ясенХуй = const, участковый = let; словесные операторы из оригинального словаря.

ясенХуй ПРИВЕТ = "Йо, мир";
сказать(ПРИВЕТ);

участковый счёт = 10;
счёт плюсуюНа;
счёт плюсуюНа;
счёт слилсяНа;
сказать("счёт:", счёт);

ясенХуй большой = счёт пизже 5 ичо чобля лож;
сказать("большой:", большой);

вилкойвглаз (счёт эквалио 11) {
    сказать("счёт равен 11");
} иливжопураз {
    сказать("счёт не 11");
}

участковый сумма = 0;
го (гыы и = 0; и поц 3; и плюсуюНа) {
    сумма = сумма + и;
}
сказать("сумма:", сумма);
