гыы [а, б, в] = [1, 2, 3];
сказать(а, б, в);

гыы [первый, ...хвост] = [10, 20, 30, 40];
сказать(первый, хвост);

гыы [, второй] = [100, 200];
сказать(второй);

гыы { имя, лет } = { имя: "Йопта", лет: 3 };
сказать(имя, лет);

гыы { х: икс, у: игрек } = { х: 7, у: 8 };
сказать(икс, игрек);

гыы { а: аа, ...прочее } = { а: 1, б: 2, в: 3 };
сказать(аа, прочее);

гыы { п = 5, к = 6 } = { п: 1 };
сказать(п, к);

гыы [[вл, вр]] = [[1, 2]];
сказать(вл, вр);

гыы { кор: { лист } } = { кор: { лист: 42 } };
сказать(лист);
