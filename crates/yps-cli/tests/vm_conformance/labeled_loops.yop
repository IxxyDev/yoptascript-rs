гыы сумма = 0;
внеш: го (гыы и = 0; и < 3; и++) {
    го (гыы к = 0; к < 3; к++) {
        вилкойвглаз (к == 2) { двигай внеш; }
        вилкойвглаз (и == 2) { харэ внеш; }
        сумма += и * 10 + к;
    }
}
сказать(сумма);

гыы счёт = 0;
метка1: потрещим (правда) {
    го (гыы дж = 0; дж < 10; дж++) {
        вилкойвглаз (дж == 5) { харэ метка1; }
        счёт++;
    }
}
сказать(счёт);
