клёво Счётчик {
    попонятия всего = 0;
    попонятия ПИ = 3.14;
    попонятия инкр() {
        тырыпыры.всего = тырыпыры.всего + 1;
        отвечаю тырыпыры.всего;
    }
    попонятия кв(х) {
        отвечаю х * х;
    }
    попонятия опис() {
        отвечаю "Счётчик=" + тырыпыры.всего;
    }
}

сказать(Счётчик.ПИ);
сказать(Счётчик.всего);
сказать(Счётчик.кв(5));
сказать(Счётчик.инкр());
сказать(Счётчик.инкр());
сказать(Счётчик.всего);
сказать(Счётчик.опис());

клёво РасшСчёт батя Счётчик {
    попонятия куб(х) {
        отвечаю х * х * х;
    }
}
сказать(РасшСчёт.ПИ);
сказать(РасшСчёт.кв(3));
сказать(РасшСчёт.куб(2));
