йопта подсветить(строки, ...значения) {
    гыы итог = "";
    гыы н = длина(строки.сырьё);
    го (гыы и = 0; и < н; и += 1) {
        итог += строки[и];
        вилкойвглаз (и < длина(значения)) {
            итог += "[" + значения[и] + "]";
        }
    }
    отвечаю итог;
}

гыы товар = "кофе";
гыы цена = 200;
сказать(подсветить`Заказ: ${товар} за ${цена} руб.`);

йопта сырьё(строки) {
    отвечаю строки.сырьё[0];
}
сказать(сырьё`строка с \n внутри`);

йопта первый(строки) {
    отвечаю строки[0];
}
сказать(первый`только текст`);
