клёво Зверь {
    Зверь(имя) {
        тырыпыры.имя = имя;
        тырыпыры.звук = "...";
    }
    голос() {
        отвечаю тырыпыры.имя + ": " + тырыпыры.звук;
    }
}

клёво Пёс батя Зверь {
    Пёс(имя) {
        яга(имя);
        тырыпыры.звук = "Гав";
    }
    голос() {
        отвечаю "Пёс " + яга.голос();
    }
}

клёво Щенок батя Пёс {
    Щенок(имя) {
        яга(имя);
        тырыпыры.звук = "Тяв";
    }
    голос() {
        отвечаю "Щенок " + яга.голос();
    }
}

гыы з = захуярить Зверь("Нечто");
сказать(з.голос());

гыы п = захуярить Пёс("Рекс");
сказать(п.голос());
сказать(п.имя);

гыы щ = захуярить Щенок("Малыш");
сказать(щ.голос());
сказать(щ.имя);

сказать(щ шкура Щенок);
сказать(щ шкура Пёс);
сказать(щ шкура Зверь);
сказать(з шкура Пёс);
