гыы a = [];
го (гыы и = 0; и < 3; и = и + 1) { a.втолкнуть(() => и); }
сказать(a[0](), a[1](), a[2]());

гыы b = [];
го (гыы x сашаГрей [10, 20, 30]) { b.втолкнуть(() => x); }
сказать(b[0](), b[1](), b[2]());

гыы c = [];
го (гыы ключ из { п: 1, р: 2 }) { c.втолкнуть(() => ключ); }
сказать(c[0](), c[1]());

пиздюли ген() {
    гыы f = [];
    го (гыы и = 0; и < 3; и = и + 1) { f.втолкнуть(() => и); }
    поебалу f[0]();
    поебалу f[1]();
    поебалу f[2]();
}
гыы рез = [];
го (гыы х сашаГрей ген()) { рез.втолкнуть(х); }
сказать(рез);

пиздюли генБлок() {
    гыы f = [];
    го (гыы и = 0; и < 3; и = и + 1) { { f.втолкнуть(() => и); } }
    го (гыы x сашаГрей [10, 20, 30]) { { f.втолкнуть(() => x); } }
    го (гыы и = 0; и < 3; и = и + 1) {
        хапнуть { f.втолкнуть(() => и); } тюряжка { }
    }
    го (гыы э сашаГрей f) { поебалу э(); }
}
гыы рез2 = [];
го (гыы х сашаГрей генБлок()) { рез2.втолкнуть(х); }
сказать(рез2);
