йопта задержка(значение, мс) {
    отвечаю захуярить СловоПацана((решить, _) => {
        чутка(() => решить(значение), мс);
    });
}

ассо йопта main() {
    сказать("старт");
    чутка(() => сказать("таймер 0мс"), 0);
    СловоПацана.решить().потом(() => сказать("микротаска до таймера"));
    гыы значение = сидетьНахуй задержка("после таймера", 10);
    сказать(значение);
    чутка(() => сказать("таймер в конце"), 5);
    сказать("конец main");
}
main();
сказать("после main");
