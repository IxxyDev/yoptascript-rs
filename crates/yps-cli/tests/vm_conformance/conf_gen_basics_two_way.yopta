пиздюли диалог() {
    гыы а = поебалу "первый";
    сказать("получил a:", а);
    гыы б = поебалу "второй";
    сказать("получил b:", б);
    отвечаю а + б;
}
гыы г = диалог();
гыы р1 = г.следующий("игнор");
сказать("y1:", р1.значение, р1.готово);
гыы р2 = г.следующий(10);
сказать("y2:", р2.значение, р2.готово);
гыы р3 = г.следующий(20);
сказать("ret:", р3.значение, р3.готово);
гыы р4 = г.следующий(99);
сказать("после:", р4.значение, р4.готово);
