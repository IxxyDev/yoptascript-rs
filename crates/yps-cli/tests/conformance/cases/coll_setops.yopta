гыы а = захуярить Набор([1, 2, 3, 4]);
гыы б = захуярить Набор([3, 4, 5, 6]);
гыы объед = а.union(б);
го (гыы в сашаГрей объед.values()) { сказать(в); }
сказать("---");
гыы пер = а.intersection(б);
го (гыы в сашаГрей пер.values()) { сказать(в); }
сказать("---");
гыы разн = а.difference(б);
го (гыы в сашаГрей разн.values()) { сказать(в); }
сказать("---");
гыы симр = а.symmetricDifference(б);
го (гыы в сашаГрей симр.values()) { сказать(в); }
сказать("---");
гыы мал = захуярить Набор([3, 4]);
сказать(мал.isSubsetOf(а));
сказать(а.isSubsetOf(мал));
сказать(а.isSupersetOf(мал));
сказать(мал.isSupersetOf(а));
гыы непер = захуярить Набор([7, 8]);
сказать(а.isDisjointFrom(непер));
сказать(а.isDisjointFrom(б));
