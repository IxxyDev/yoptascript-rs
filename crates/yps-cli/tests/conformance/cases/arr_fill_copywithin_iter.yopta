сказать([1, 2, 3, 4, 5].fill(0).join(","));
сказать([1, 2, 3, 4, 5].fill(0, 1, 3).join(","));
сказать([1, 2, 3, 4, 5].fill(0, -3).join(","));
сказать([1, 2, 3, 4, 5].copyWithin(0, 3).join(","));
сказать([1, 2, 3, 4, 5].copyWithin(1, 3).join(","));
сказать([1, 2, 3, 4, 5].copyWithin(-2, -3, -1).join(","));

гыы f = ["a", "b", "c"];
