ясенХуй м = { значение: 42, дай() { отвечаю тырыпыры.значение; } };
сказать(м.дай());

ясенХуй ф = м.дай;
хапнуть { сказать(ф()); } гоп(е) { сказать("ошибка"); }

клёво Т {
  Т() { тырыпыры.х = 10; }
  стрела = () => тырыпыры.х;
  обычный() { отвечаю тырыпыры.х; }
}
ясенХуй т = захуярить Т();
сказать(т.обычный());
сказать(т.стрела());

ясенХуй стр = т.стрела;
сказать(стр());

ясенХуй обыч = т.обычный;
хапнуть { сказать(обыч()); } гоп(е) { сказать("ошибка"); }
