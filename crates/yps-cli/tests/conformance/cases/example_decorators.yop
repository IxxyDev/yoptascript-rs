йопта лог(метод, контекст) {
    гыы имя = контекст.имя;
    отвечаю (...аргс) => {
        сказать("[" + имя + "] вызов");
        гыы результат = метод(аргс[0], аргс[1]);
        сказать("[" + имя + "] результат: " + результат);
        отвечаю результат;
    };
}

клёво Калькулятор {
    @лог
    сложить(а, б) {
        отвечаю а + б;
    }

    @лог
    умножить(а, б) {
        отвечаю а * б;
    }
}

гыы к = захуярить Калькулятор();
к.сложить(2, 3);
к.умножить(4, 5);
