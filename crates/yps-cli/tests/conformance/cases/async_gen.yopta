ассо йопта удвоить(н) {
    отвечаю н * 2;
}

ассо пиздюли числа() {
    поебалу сидетьНахуй удвоить(1);
    поебалу сидетьНахуй удвоить(2);
    поебалуна [10, 20];
}

ассо йопта главная() {
    го сидетьНахуй (гыы х сашаГрей числа()) {
        сказать(х);
    }
    сказать("готово");
}

главная();
