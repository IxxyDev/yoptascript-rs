клёво База {
  get вид() { отвечаю "база"; }
}
клёво Под батя База {}
участковый п = захуярить Под();
сказать(п.вид);

клёво Ж {
  Ж() { тырыпыры._х = 10; }
  get х() { отвечаю тырыпыры._х; }
  set х(в) { тырыпыры._х = в; }
}
клёво Д батя Ж {
  Д() { яга(); }
}
участковый д = захуярить Д();
сказать(д.х);
д.х = 99;
сказать(д.х);
