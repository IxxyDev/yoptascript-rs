участковый м = { значение: 42, дай() { отвечаю тырыпыры.значение; } };
сказать(м.дай());

участковый ф = м.дай;
хапнуть { сказать(ф()); } гоп(е) { сказать("ошибка"); }

клёво Т {
  Т() { тырыпыры.х = 10; }
  стрела = () => тырыпыры.х;
  обычный() { отвечаю тырыпыры.х; }
}
участковый т = захуярить Т();
сказать(т.обычный());
сказать(т.стрела());

участковый стр = т.стрела;
сказать(стр());

участковый обыч = т.обычный;
хапнуть { сказать(обыч()); } гоп(е) { сказать("ошибка"); }
