клёво Счёт {
  попонятия сумма = 0;
  попонятия {
    гыы шаг = 5;
    тырыпыры.сумма = тырыпыры.сумма + шаг;
  }
  попонятия удвой() { отвечаю тырыпыры.сумма * 2; }
  попонятия {
    тырыпыры.итог = тырыпыры.удвой();
  }
}
сказать(Счёт.сумма);
сказать(Счёт.итог);

клёво Расш батя Счёт {
  попонятия {
    тырыпыры.метка = "расш:" + тырыпыры.сумма;
  }
}
сказать(Расш.сумма);
сказать(Расш.метка);
