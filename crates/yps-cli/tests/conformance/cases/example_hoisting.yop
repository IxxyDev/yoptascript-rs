// Подъём (hoisting) объявлений функций:
// функцию можно вызвать до строки её объявления

сказать(приветствие("Мир"));   // Привет, Мир!

йопта приветствие(имя) {
    отвечаю "Привет, " + имя + "!";
}

// Взаимная рекурсия тоже работает без предварительного объявления
сказать(чётное(10));  // правда

йопта чётное(н) {
    вилкойвглаз (н == 0) { отвечаю правда; }
    отвечаю нечётное(н - 1);
}

йопта нечётное(н) {
    вилкойвглаз (н == 0) { отвечаю лож; }
    отвечаю чётное(н - 1);
}
