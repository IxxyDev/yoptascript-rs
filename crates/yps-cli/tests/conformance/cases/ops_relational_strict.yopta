йопта проверь(ф) {
  хапнуть {
    отвечаю строка(ф());
  } гоп (е) {
    отвечаю "ошибка";
  }
}
сказать(проверь(() => "10" < "9"));
сказать(проверь(() => "10" < 9));
сказать(проверь(() => ноль < 1));
сказать(проверь(() => неибу < 1));
сказать(проверь(() => правда < 2));
сказать(проверь(() => 5 < 3));
сказать(проверь(() => 3 <= 3));
сказать(проверь(() => 7 > 2));
сказать(проверь(() => 2 >= 9));
