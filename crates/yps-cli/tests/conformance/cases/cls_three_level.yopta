клёво А {
  А() { тырыпыры.а = "a"; }
  метА() { отвечаю "А"; }
}
клёво Б батя А {
  Б() { яга(); тырыпыры.б = "b"; }
  метБ() { отвечаю яга.метА() + "+Б"; }
}
клёво В батя Б {
  В() { яга(); тырыпыры.в = "c"; }
}
ясенХуй в = захуярить В();
сказать(в.а);
сказать(в.б);
сказать(в.в);
сказать(в.метБ());
сказать(в шкура А);
сказать(в шкура Б);
сказать(в шкура В);
