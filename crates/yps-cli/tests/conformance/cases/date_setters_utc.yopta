гыы д = захуярить Дата(Дата.разобрать("2020-01-01T00:00:00Z"));
сказать(д.поставитьМесяц(13));
сказать(д.вИСО());
сказать(д.поставитьДень(0));
сказать(д.вИСО());
гыы д2 = захуярить Дата(Дата.разобрать("2020-01-01T10:30:15.500Z"));
сказать(д2.поставитьЧасы(25));
сказать(д2.вИСО());
сказать(д2.поставитьМинуты(1, 90));
сказать(д2.вИСО());
гыы д3 = захуярить Дата(0);
сказать(д3.поставитьГод(2021, 5, 15));
сказать(д3.вИСО());
сказать(д3.годUTC() === д3.год());
сказать(д3.смещениеЧасовогоПояса());
гыы плохая = захуярить Дата("не дата");
