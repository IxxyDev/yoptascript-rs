плохая.поставитьГод(2022);
сказать(плохая.вИСО());
сказать(Дата.разобрать("2026-07-19"));
сказать(Дата.разобрать("2026-07-19T12:00:00Z"));
сказать(Дата.разобрать("2026-07-19T12:00:00+02:00"));
сказать(Дата.разобрать("2026-07-19T12:00:00"));
сказать(Дата.разобрать("не дата"));
