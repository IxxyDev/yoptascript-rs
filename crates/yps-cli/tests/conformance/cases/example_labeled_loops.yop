// Помеченные циклы: харэ/двигай по метке

// harэ по метке прерывает ВНЕШНИЙ цикл
поиск: го (гыы и = 0; и < 3; и += 1) {
    го (гыы ж = 0; ж < 3; ж += 1) {
        вилкойвглаз (и == 1 && ж == 1) {
            сказать("нашли на " + и + "," + ж);
            харэ поиск;
        }
    }
}

// двигай по метке продолжает ВНЕШНИЙ цикл, пропуская остаток внутреннего
строки: го (гыы р = 0; р < 3; р += 1) {
    го (гыы к = 0; к < 3; к += 1) {
        вилкойвглаз (к == 1) {
            двигай строки;
        }
        сказать("ячейка " + р + "," + к);
    }
}
