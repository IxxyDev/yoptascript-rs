ассо йопта демо() {
    сидетьНахуй подождать(30);
    сказать("после подождать(30)");

    гыы контроллёр = захуярить КонтроллёрОтмены();
    чутка(() => контроллёр.отменить("стоп"), 10);
    хапнуть {
        сидетьНахуй подождать(200, { сигнал: контроллёр.сигнал });
        сказать("не должно сюда дойти");
    } гоп (e) {
        сказать("ожидание отменено:", e.message);
    }

    гыы итог = сидетьНахуй СловоПацана.гонка([
        подождать(50),
        захуярить СловоПацана((решить, _) => { чутка(() => решить("быстрее"), 5); })
    ]);
    сказать("гонка дала:", итог);

    гыы сигналТо = СигналОтмены.отВремени(10);
    хапнуть {
        сидетьНахуй сигналТо.обещание;
    } гоп (e) {
        сказать("отВремени:", e.message);
    }
}

демо();
