гыы об = { вЧисло: йопта() { отвечаю 42; } };
сказать("valueOf+0:", об + 0);
сказать("valueOf==42:", об == 42);

гыы стр = { вСтроку: йопта() { отвечаю "привет"; } };
сказать("toString-concat:", "" + стр);

гыы оба = {
    вЧисло: йопта() { отвечаю 7; },
    вСтроку: йопта() { отвечаю "семь"; }
};
сказать("default-valueOf:", оба + 1);

гыы сприм = {
    вПримитив: йопта(п) { отвечаю 100; },
    вЧисло: йопта() { отвечаю 1; }
};
сказать("вПримитив-приоритет:", сприм + 0);
