гыы { а = 5 } = { а: ноль };
сказать(а);

гыы { б = 5 } = { б: неибу };
сказать(б);

гыы { в = 5 } = { в: 0 };
сказать(в);

гыы { г: псевдо = "по умолчанию" } = {};
сказать(псевдо);

гыы { г: псевдо2 = "по умолчанию" } = { г: "значение" };
сказать(псевдо2);

гыы [п, , т] = [1, 2, 3];
сказать(п);
сказать(т);

гыы [х = 10, у = 20] = [1];
сказать(х);
сказать(у);

гыы { внешний: { внутренний } } = { внешний: { внутренний: 77 } };
сказать(внутренний);

йопта тест(имя, счёт) {
  сказать(имя);
  сказать(счёт);
}
тест("йопта", 5);
тест("мир", 0);
