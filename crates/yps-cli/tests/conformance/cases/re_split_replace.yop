йопта показ(массив) {
    сказать(массив.длина + " :: " + массив.join("|"));
}
показ("a1b2c3".split(/\d/));
показ("a, b,  c,   d".split(/,\s*/));
показ("abc".split(/x/));
показ("2026-06-12".split(/-/));
показ("axbxc".split(/(x)/));
сказать("---replace regex groups---");
сказать("2026-06-12".заменить(/(\d+)-(\d+)-(\d+)/, "$3/$2/$1"));
сказать("hello world".заменитьВсе(/(\w)(\w*)/g, "$2$1"));
сказать("a1b2".заменить(/([a-z])(\d)/g, "$2$1"));
