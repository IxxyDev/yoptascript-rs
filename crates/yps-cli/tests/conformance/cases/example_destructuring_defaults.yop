// Деструктуризация со значениями по умолчанию (ES6)

// Объект: shorthand с default и переименование с default
гыы { ширина = 100, высота = 50 } = { ширина: 800 };
сказать(ширина);  // 800 (взято из объекта)
сказать(высота);  // 50  (значение по умолчанию)

гыы { цвет: оттенок = "чёрный" } = {};
сказать(оттенок); // чёрный

// Default может ссылаться на ранее связанные имена
гыы { сторона = 4, площадь = сторона * сторона } = { сторона: 5 };
сказать(площадь); // 25

// Массив: пропущенные элементы получают default
гыы [первый, второй = 2, третий = 3] = [10];
сказать(первый); // 10
сказать(второй); // 2
сказать(третий); // 3
