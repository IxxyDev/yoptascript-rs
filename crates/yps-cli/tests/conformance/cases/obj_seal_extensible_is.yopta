гыы o1 = {а: 1, б: 2};
Кент.запечатать(o1);
o1.а = 100;
o1.в = 3;
ёбнуть o1.б;
сказать(o1.а, Кент.имеетСвоё(o1, "в"), Кент.имеетСвоё(o1, "б"), Кент.запечатан(o1), Кент.расширяем(o1));

гыы o2 = {х: 1, у: 2};
Кент.запретитьРасширение(o2);
o2.х = 42;
o2.з = 5;
ёбнуть o2.у;
сказать(o2.х, Кент.имеетСвоё(o2, "з"), Кент.имеетСвоё(o2, "у"), Кент.запечатан(o2), Кент.расширяем(o2));

гыы o3 = {п: 1};
Кент.заморозить(o3);
сказать(Кент.заморожен(o3), Кент.запечатан(o3), Кент.расширяем(o3));

сказать(Кент.запечатан(5), Кент.расширяем(5), Кент.заморожен(неибу));

сказать(Кент.есть(нихуя, нихуя), Кент.есть(0, -0), Кент.есть(1, 1), Кент.есть("a", "a"));

гыы parentA = {х: "a"};
гыы parentB = {х: "b"};
гыы o4 = Кент.создать(parentA);
Кент.запретитьРасширение(o4);
Кент.назначитьПрототип(o4, parentB);
сказать(Кент.прототип(o4).х);
Кент.назначитьПрототип(o4, parentA);
сказать(Кент.прототип(o4).х);

гыы t = {};
Кент.запретитьРасширение(t);
Кент.назначить(t, {а: 1, б: 2});
сказать(Кент.имеетСвоё(t, "а"), Кент.имеетСвоё(t, "б"));

гыы o5 = {а: 1};
Кент.запретитьРасширение(o5);
Кент.определитьСвойство(o5, "б", {значение: 2});
Кент.определитьСвойство(o5, "а", {значение: 99});
сказать(Кент.имеетСвоё(o5, "б"), o5.а);

гыы o6 = {};
Кент.определитьСвойства(o6, {а: {значение: 1}, б: {значение: 2}});
гыы d6 = Кент.описатьСвойства(o6);
сказать(d6.а.значение, d6.б.значение);
