гыы лог = [];

ясенХуй мишень = { а: 1, б: 2 };
ясенХуй наблюдатель = захуярить Посредник(мишень, {
  собственныеКлючи: (ц) => { втолкнуть(лог, "ownKeys"); отвечаю Отражение.собственныеКлючи(ц); },
  определитьСвойство: (ц, к, деск) => { втолкнуть(лог, "define:" + к); отвечаю Отражение.определитьСвойство(ц, к, деск); },
  описатьСвойство: (ц, к) => { втолкнуть(лог, "descr:" + к); отвечаю Отражение.описатьСвойство(ц, к); },
  запретитьРасширение: (ц) => { втолкнуть(лог, "prevent"); отвечаю Отражение.запретитьРасширение(ц); },
  расширяем: (ц) => Отражение.расширяем(ц)
});

сказать(Отражение.собственныеКлючи(наблюдатель).склеить(","));
Кент.определитьСвойство(наблюдатель, "в", { значение: 3 });
сказать(Кент.описатьСвойство(наблюдатель, "в").значение);
сказать(Кент.расширяем(наблюдатель));
Кент.запретитьРасширение(наблюдатель);
сказать(Кент.расширяем(наблюдатель));
сказать(Отражение.собственныеКлючи(наблюдатель).склеить(","));
сказать(лог.склеить("|"));

ясенХуй ядро = { счёт: 10 };
ясенХуй зеркало = захуярить Посредник(ядро, {
  получить: (ц, к, пр) => Отражение.получить(ц, к),
  установить: (ц, к, зн, пр) => Отражение.установить(ц, к, зн),
  есть: (ц, к) => Отражение.есть(ц, к),
  удалить: (ц, к) => Отражение.удалить(ц, к),
  собственныеКлючи: (ц) => Отражение.собственныеКлючи(ц)
});

зеркало.имя = "зеркальный";
сказать(зеркало.счёт, зеркало.имя);
сказать("счёт" чоунастут зеркало);
сказать(Кент.ключи(зеркало).склеить(","));
ёбнуть зеркало.счёт;
сказать("счёт" чоунастут зеркало, зеркало.имя);

ясенХуй прото = { вид: "прототип" };
ясенХуй сменщик = захуярить Посредник({}, {
  назначитьПрототип: (ц, прт) => Отражение.назначитьПрототип(ц, прт),
  прототипОт: (ц) => Отражение.прототипОт(ц)
});
Кент.назначитьПрототип(сменщик, прото);
сказать(Кент.прототип(сменщик).вид);
