йопта тег(строки, ...значения) {
    гыы р = "";
    го (гыы и = 0; и < строки.длина; и += 1) {
        р += строки.raw[и];
        вилкойвглаз (и < значения.длина) {
            р += "<" + значения[и] + ">";
        }
    }
    отвечаю р;
}
гыы имя = "Мир";
сказать(тег`Привет, ${имя}!\n`);

