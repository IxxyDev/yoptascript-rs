гыы лог = [];
го (гыы и = 0; и < 5; и += 1) {
  хапнуть {
    вилкойвглаз (и === 2) { харэ; }
    лог.втолкнуть("б:" + и);
  } тюряжка {
    лог.втолкнуть("f:" + и);
  }
}
сказать(лог.join(","));
гыы лог2 = [];
го (гыы к = 0; к < 3; к += 1) {
  хапнуть {
    вилкойвглаз (к === 1) { двигай; }
    лог2.втолкнуть("т:" + к);
  } тюряжка {
    лог2.втолкнуть("ф:" + к);
  }
}
сказать(лог2.join(","));
