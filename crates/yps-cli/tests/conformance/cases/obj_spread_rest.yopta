участковый сл1 = { а: 1, б: 2 };
участковый сл2 = { б: 99, в: 3 };
участковый объед = { ...сл1, ...сл2 };
сказать(объед.а);
сказать(объед.б);
сказать(объед.в);

участковый м1 = [1, 2];
участковый м2 = [0, ...м1, 3];
сказать(м2.длина);
сказать(м2[0]);
сказать(м2[1]);
сказать(м2[2]);
сказать(м2[3]);

гыы { имя, ...прочее } = { имя: "Ян", возраст: 30, город: "М" };
сказать(имя);
сказать(прочее.возраст);
сказать(прочее.город);

гыы [пер, ...хвост] = [10, 20, 30];
сказать(пер);
сказать(хвост.длина);
сказать(хвост[0]);

йопта сумм(...нс) { гыы с = 0; го (гыы н из нс) { с = с + н; } отвечаю с; }
участковый арги = [1, 2, 3, 4];
сказать(сумм(...арги));
