йопта задержка(значение, мс) {
    отвечаю захуярить СловоПацана((решить, _) => {
        чутка(() => решить(значение), мс);
    });
}
йопта отказЧерез(причина, мс) {
    отвечаю захуярить СловоПацана((_, отвергнуть) => {
        чутка(() => отвергнуть(причина), мс);
    });
}

ассо йопта main() {
    гыы первый = сидетьНахуй СловоПацана.гонка([
        задержка("медленный", 20),
        задержка("быстрый", 5)
    ]);
    сказать("гонка fulfill:", первый);

    хапнуть {
        сидетьНахуй СловоПацана.гонка([
            отказЧерез("ранний отказ", 5),
            задержка("поздний успех", 20)
        ]);
    } гоп (e) {
        сказать("гонка reject:", e);
    }

    гыы выбор = сидетьНахуй СловоПацана.любой([
        отказЧерез("боль1", 5),
        задержка("успех", 10),
        отказЧерез("боль2", 2)
    ]);
    сказать("любой:", выбор);

    хапнуть {
        сидетьНахуй СловоПацана.любой([
            СловоПацана.отвергнуть("e1"),
            СловоПацана.отвергнуть("e2")
        ]);
    } гоп (e) {
        сказать("любой все отклонены, errors длина:", e.errors.длина);
        сказать(e.errors[0]);
        сказать(e.errors[1]);
    }
}
main();
