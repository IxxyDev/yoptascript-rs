ассо йопта main() {
    гыы p = СловоПацана.решить(0);
    сказать("старт");
    p.потом(() => {
        сказать("внешний A");
        СловоПацана.решить().потом(() => сказать("вложенный A"));
    });
    p.потом(() => {
        сказать("внешний B");
        СловоПацана.решить().потом(() => сказать("вложенный B"));
    });
    сказать("конец синхронного");
    сидетьНахуй СловоПацана.решить()
        .потом(() => ноль)
        .потом(() => ноль)
        .потом(() => ноль);
}
main();
