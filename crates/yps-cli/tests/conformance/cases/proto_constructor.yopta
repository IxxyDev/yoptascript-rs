клёво Животное {
  конструктор(имя) {
    тырыпыры.имя = имя;
  }
}

клёво Пёс батя Животное {
  конструктор(имя) {
    яга(имя);
  }
}

гыы пёс = захуярить Пёс("Бобик");

сказать(пёс.конструктор === Пёс);
сказать(Пёс.prototype.конструктор === Пёс);
сказать(Животное.prototype.конструктор === Животное);
сказать(Пёс.prototype === Пёс.prototype);
