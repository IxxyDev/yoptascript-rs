гыы числа = [10, 9, 1, 200, 3];
сказать(числа.sort().join(","));
гыы поУбыв = [10, 9, 1, 200, 3].sort((а, б) => б - а);
сказать(поУбыв.join(","));
гыы поВозр = [10, 9, 1, 200, 3].sort((а, б) => а - б);
сказать(поВозр.join(","));
гыы исходный = [3, 1, 2];
гыы вернулось = исходный.sort();
сказать(вернулось === исходный);
гыы люди = [
    {имя: "Аня", возраст: 30, порядок: 0},
    {имя: "Боб", возраст: 25, порядок: 1},
    {имя: "Вера", возраст: 30, порядок: 2},
    {имя: "Гена", возраст: 25, порядок: 3}
];
люди.sort((а, б) => а.возраст - б.возраст);
го (гыы ч сашаГрей люди) {
    сказать(ч.возраст + ":" + ч.порядок);
}
гыы сМестом = [3, неибу, 1, 2];
сМестом.sort();
го (гыы э сашаГрей сМестом) {
    сказать(строка(э));
}
