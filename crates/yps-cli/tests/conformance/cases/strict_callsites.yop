гыы результат = "нет";
базарпо (1) {
    тема "1": {
        результат = "строка1";
    }
    тема 1: {
        результат = "число1";
    }
    нуичо {
        результат = "дефолт";
    }
}
сказать("свитч:", результат);

гыы мас = [1, 2, 3];
сказать("includes(1):", мас.включает(1));
