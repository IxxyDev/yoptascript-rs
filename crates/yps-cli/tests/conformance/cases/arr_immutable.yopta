гыы исх = [3, 1, 2];
гыы отсорт = исх.toSorted((а, б) => а - б);
сказать(отсорт.join(","));
сказать(исх.join(","));

гыы исх2 = [1, 2, 3];
гыы перев = исх2.toReversed();
сказать(перев.join(","));
сказать(исх2.join(","));

гыы исх3 = [1, 2, 3, 4, 5];
гыы спл = исх3.toSpliced(1, 2, 99);
сказать(спл.join(","));
сказать(исх3.join(","));

гыы исх4 = [1, 2, 3];
гыы зам = исх4.with(1, 99);
сказать(зам.join(","));
сказать(исх4.join(","));

гыы исх5 = [1, 2, 3];
гыы замОтр = исх5.with(-1, 99);
сказать(замОтр.join(","));

хапнуть {
    [1, 2, 3].with(5, 0);
} гоп(е) {
    сказать("with-вне-диапазона-поймано");
}
хапнуть {
    [1, 2, 3].with(-5, 0);
} гоп(е) {
    сказать("with-отриц-вне-поймано");
}
