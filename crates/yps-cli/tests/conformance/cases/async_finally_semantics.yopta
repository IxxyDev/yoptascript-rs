ассо йопта main() {
    гыы а = сидетьНахуй СловоПацана.решить("значение")
        .наконец(() => сказать("наконец 1 выполнен"));
    сказать("после наконец:", а);

    гыы б = сидетьНахуй СловоПацана.решить("исходное")
        .наконец(() => "это игнорируется");
    сказать("наконец не меняет значение:", б);

    хапнуть {
        сидетьНахуй СловоПацана.решить("ок")
            .наконец(() => { кидай "из наконец"; });
    } гоп (e) {
        сказать("наконец заменяет throw-ом:", e);
    }
}
main();
