ассо йопта main() {
    гыы итог = сидетьНахуй СловоПацана.решить(1)
        .потом((v) => v + 10)
        .потом((v) => v * 2);
    сказать("цепочка:", итог);

    гыы вложен = сидетьНахуй СловоПацана.решить(5)
        .потом((v) => СловоПацана.решить(v * 100));
    сказать("вложенный потом:", вложен);

    хапнуть {
        сидетьНахуй СловоПацана.решить(1)
            .потом(() => { кидай "ошибка в потом"; })
            .потом(() => сказать("этот потом пропущен"));
    } гоп (e) {
        сказать("поймано из цепочки:", e);
    }

    гыы черезЛовить = сидетьНахуй СловоПацана.отвергнуть("боль")
        .ловить((e) => "восстановлено: " + e);
    сказать(черезЛовить);
}
main();
