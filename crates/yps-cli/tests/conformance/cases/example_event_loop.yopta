сказать("=== Таймеры ===");

чутка(() => сказать("задержка 30мс"), 30);
чутка(() => сказать("задержка 5мс"), 5);
сразу(() => сказать("микротаска"));

сказать("конец синхронного блока");

сидетьНахуй захуярить СловоПацана((решить, _) => чутка(() => решить(ноль), 40));

сказать("=== Интервал ===");

гыы счёт = 0;
гыы ид = ноль;
сидетьНахуй захуярить СловоПацана((решить, _) => {
    ид = интервал(() => {
        счёт = счёт + 1;
        сказать("тик", счёт);
        вилкойвглаз (счёт >= 3) {
            отменаИнтервала(ид);
            сказать("интервал остановлен");
            решить(ноль);
        }
    }, 10);
});

сказать("=== Async/await с задержкой ===");

йопта задержка(значение, мс) {
    отвечаю захуярить СловоПацана((решить, _) => {
        чутка(() => решить(значение), мс);
    });
}

ассо йопта собрать() {
    гыы а = сидетьНахуй задержка(1, 20);
    гыы б = сидетьНахуй задержка(2, 20);
    гыы в = сидетьНахуй задержка(3, 20);
    отвечаю а + б + в;
}

сидетьНахуй собрать().потом((итог) => сказать("сумма:", итог));

сказать("=== Top-level await ===");
гыы х = сидетьНахуй задержка("привет из await", 5);
сказать(х);

сказать("=== Reject через await + try/catch ===");
ассо йопта рискованно() {
    отвечаю захуярить СловоПацана((_, отвергнуть) => {
        чутка(() => отвергнуть("плохо вышло"), 5);
    });
}
ассо йопта поймать() {
    хапнуть {
        сидетьНахуй рискованно();
    } гоп (e) {
        сказать("поймано:", e);
    }
}
сидетьНахуй поймать();

сказать("=== Throw в timer не убивает loop ===");
чутка(() => { кидай "ошибка в таймере"; }, 1);
чутка(() => сказать("следующий таймер всё ещё работает"), 5);
