йопта проверь(ф) {
  хапнуть {
    отвечаю строка(ф());
  } гоп (е) {
    отвечаю "ошибка";
  }
}
сказать(проверь(() => +"5"));
сказать(проверь(() => +""));
сказать(проверь(() => +"abc"));
сказать(проверь(() => +правда));
сказать(проверь(() => +ноль));
сказать(проверь(() => +неибу));
сказать(проверь(() => -"3"));
сказать(проверь(() => +42));
сказать(проверь(() => -42));
