// Теговые шаблонные строки (tagged template literals)

// Тег получает массив строковых сегментов и значения подстановок
йопта подсветить(строки, ...значения) {
    гыы итог = "";
    го (гыы и = 0; и < строки.длина; и += 1) {
        итог += строки[и];
        вилкойвглаз (и < значения.длина) {
            итог += "[" + значения[и] + "]";
        }
    }
    отвечаю итог;
}

гыы товар = "кофе";
гыы цена = 200;
сказать(подсветить`Заказ: ${товар} за ${цена} руб.`);
// Заказ: [кофе] за [200] руб.

// Поле .сырьё (raw) хранит необработанные escape-последовательности
йопта сырьё(строки) {
    отвечаю строки.сырьё[0];
}
сказать(сырьё`строка с \n внутри`);
// строка с \n внутри  (обратный слеш сохранён, без реального переноса)
