участковый об = {
  _н: 5,
  get н() { отвечаю тырыпыры._н * 2; },
  set н(в) { тырыпыры._н = в + 1; }
};
сказать(об.н);
об.н = 10;
сказать(об._н);
сказать(об.н);

клёво Ячейка {
  Ячейка() { тырыпыры._ц = 0; }
  get удвоить() { отвечаю тырыпыры._ц * 2; }
  set уст(в) { тырыпыры._ц = в; }
}
участковый я = захуярить Ячейка();
я.уст = 4;
сказать(я.удвоить);
я.уст = 7;
сказать(я.удвоить);
