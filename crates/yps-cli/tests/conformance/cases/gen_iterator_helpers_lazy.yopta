пиздюли источник() {
    гыы и = 0;
    потрещим (правда) {
        сказать("выдаю", и);
        поебалу и;
        и = и + 1;
    }
}
гыы рез = Итератор.от(источник())
    .преобразовать((н) => { сказать("map", н); отвечаю н * 10; })
    .отфильтровать((н) => { сказать("filter", н); отвечаю н % 20 == 0; })
    .взять(2)
    .вМассив();
сказать("длина:", рез.длина);
сказать(рез[0]);
сказать(рез[1]);

гыы числа = [1, 2, 3, 4, 5, 6, 7, 8];
гыы первыеТри = Итератор.от(числа).пропустить(2).взять(3).вМассив();
сказать("drop+take длина:", первыеТри.длина);
сказать(первыеТри[0]);
сказать(первыеТри[1]);
сказать(первыеТри[2]);
