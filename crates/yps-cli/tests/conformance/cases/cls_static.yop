клёво Мат {
  попонятия ПИ = 3.14;
  попонятия кв(х) { отвечаю х * х; }
  попонятия описание() { отвечаю "Мат(" + тырыпыры.ПИ + ")"; }
}
сказать(Мат.ПИ);
сказать(Мат.кв(4));
сказать(Мат.описание());

клёво РасшМат батя Мат {
  попонятия куб(х) { отвечаю х * х * х; }
}
сказать(РасшМат.ПИ);
сказать(РасшМат.кв(3));
сказать(РасшМат.куб(2));
