ассо йопта возвращает(значение) {
    отвечаю значение;
}
ассо йопта бросает() {
    кидай "ошибка внутри async";
}
ассо йопта ждётОтклонение() {
    хапнуть {
        сидетьНахуй СловоПацана.отвергнуть("отклонённое обещание");
    } гоп (e) {
        отвечаю "поймано: " + e;
    }
}

ассо йопта main() {
    гыы значение = сидетьНахуй возвращает(123);
    сказать("async вернул:", значение);

    гыы безОбещания = сидетьНахуй 42;
    сказать("await не-обещания:", безОбещания);

    хапнуть {
        сидетьНахуй бросает();
    } гоп (e) {
        сказать("throw в async →", e);
    }

    гыы результат = сидетьНахуй ждётОтклонение();
    сказать(результат);

    гыы цепь = возвращает("через потом");
    цепь.потом((v) => сказать("async как обещание:", v));
}
main();
